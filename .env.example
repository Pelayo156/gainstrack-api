# ============================================================
# GainsTrack API — Variables de entorno
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ============================================================

# Perfil de Spring Boot
# Opciones: dev | test | prod
SPRING_PROFILES_ACTIVE=test
SERVER_PORT=

# Base de datos
# En contenedor usar el nombre del contenedor MySQL como host
# Ejemplo local: jdbc:mysql://localhost:3306/gainstrack_dev
DB_URL=jdbc:mysql://<host>:<puerto>/<base_de_datos>
DB_USERNAME=
DB_PASSWORD=

# JWT
# Generar un secreto Base64 seguro con:
# openssl rand -base64 32
JWT_SECRET=
# Expiración en milisegundos (default: 30 días = 2592000000)
JWT_EXPIRATION=2592000000
